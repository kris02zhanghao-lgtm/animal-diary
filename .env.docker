# Docker 环境变量配置示例
# 复制此文件为 .env，然后填入你的实际密钥

# ===== 前端配置 (Supabase) =====
# 从 https://supabase.com 项目 Settings → API 获取
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key_here

# ===== 前端配置 (高德地图) =====
# 从 https://lbs.amap.com 申请
VITE_AMAP_KEY=your_amap_key_here
VITE_AMAP_SECURITY_CODE=your_amap_security_code_here

# ===== 后端配置 (OpenRouter API) =====
# 从 https://openrouter.ai/keys 获取 API Key
OPENROUTER_API_KEY=sk-or-v1-your_api_key_here

# ===== 后端配置 (Supabase Service Role) =====
# 如果需要后端调用Supabase，从 Settings → API → Service Role Secret 获取
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
